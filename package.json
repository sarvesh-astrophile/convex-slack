{
    "name": "open-slack",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "zod": "^4.1.13",
            "lucide-react": "^0.546.0",
            "next-themes": "^0.4.6",
            "react": "^19.2.3",
            "react-dom": "^19.2.3",
            "sonner": "^2.0.5",
            "tailwindcss": "^4.1.18",
            "convex": "^1.33.1",
            "@types/react": "^19.2.10",
            "@types/react-dom": "^19.2.3",
            "alchemy": "^0.90.0"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "check-types": "turbo check-types",
        "dev:web": "turbo -F @open-slack/infra dev",
        "dev:server": "turbo -F @open-slack/backend dev",
        "dev:setup": "turbo -F @open-slack/backend dev:setup",
        "deploy": "turbo -F @open-slack/infra deploy",
        "destroy": "turbo -F @open-slack/infra destroy",
        "check": "biome check --write ."
    },
    "dependencies": {
        "@open-slack/env": "workspace:*",
        "dotenv": "catalog:",
        "install": "^0.13.0",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@cloudflare/workers-types": "^4.20251213.0",
        "@open-slack/config": "workspace:*",
        "turbo": "^2.8.12",
        "typescript": "^5"
    },
    "packageManager": "bun@1.3.3"
}
